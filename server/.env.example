# Copy to server/.env and fill in. Never commit the real .env.

# MongoDB Atlas connection string (add /checklist before the ? to name the DB)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxx.mongodb.net/checklist?retryWrites=true&w=majority

# Port the API listens on (Render sets this automatically in production)
PORT=5000

# Allowed CORS origin in production — your deployed client URL.
# Leave unset locally to allow all origins.
CLIENT_URL=http://localhost:5173

# Public-demo self-reset. When "true", the server wipes the DB and re-seeds the
# default sample data on startup and on a timer, so visitor edits don't persist.
# Leave unset (or "false") for a normal/private deployment where data should stay.
DEMO_RESET=true

# How often (minutes) to re-seed while the server is awake. Default 180 (3h).
RESET_INTERVAL_MINUTES=180
